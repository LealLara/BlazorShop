@page "/produtos"
@inject IProdutoService produtoService

<div class="container-fluid">

    <h3 class="mb-4">Produtos</h3>

    @if (Produtos == null)
    {
        <h3>Carregando produtos...</h3>
    }
    else if (Produtos.Any())
    {
        <div class="row g-4">

            @foreach (var produto in Produtos)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm">

                        <img src="@produto.ImagemUrl"
                             class="card-img-top"
                             alt="@produto.Nome"
                             style="height:100px; object-fit:cover;" />

                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title">@produto.Nome</h5>

                            <p class="card-text text-muted">
                                @produto.Descricao
                            </p>

                            <p>
                                <strong>Categoria:</strong> @produto.CategoriaNome
                            </p>

                            <p>
                                <strong>Estoque:</strong> @produto.Quantidade
                            </p>

                            <h4 class="text-success">
                                @produto.Preco.ToString("C")
                            </h4>

                         @*    <a href="/produto/@produto.Id" class="btn btn-primary mt-auto">
                                Ver detalhes
                            </a> *@

                        </div>

                    </div>
                </div>
            }

        </div>
    }
    else
    {
        <div class="alert alert-info">
            Nenhum produto encontrado.
        </div>
    }

</div>

@code {
    public IEnumerable<ProdutoDTO>? Produtos { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Produtos = await produtoService.GetItens();
    }
}