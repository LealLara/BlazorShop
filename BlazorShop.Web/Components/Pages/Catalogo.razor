@page "/produtos"
@inject IProdutoService produtoService

<div class="container-fluid">

    <h3 class="mb-4">Produtos</h3>

    <div class="row g-4">
        @if (Produtos == null)
        {
            <h3>Carregando produtos...</h3>
        }
        else
        { 
            @if (Produtos != null && Produtos.Any())
            {
                <div class="row g-4">

                    @foreach (var produto in Produtos)
                    {
                        <div class="col-sm-6 col-md-4 col-lg-3">
                            <div class="card h-100 shadow-sm">

                                <img src="@produto.ImagemUrl"
                                     class="card-img-top"
                                     alt="@produto.Nome"
                                     style="height:250px; object-fit:cover;">

                                <div class="card-body d-flex flex-column">

                                    <h5 class="card-title">@produto.Nome</h5>

                                    <p class="card-text text-muted">
                                        @produto.Descricao
                                    </p>

                                    <p class="mb-1">
                                        <strong>Categoria:</strong> @produto.CategoriaNome
                                    </p>

                                    <p class="mb-2">
                                        <strong>Estoque:</strong> @produto.Quantidade
                                    </p>

                                    <h4 class="text-success mb-3">
                                        @produto.Preco.ToString("C")
                                    </h4>

                                    <a href="/produto/@produto.Id" class="btn btn-primary mt-auto">
                                        Ver detalhes
                                    </a>

                                </div>

                            </div>
                        </div>
                    }

                </div>
            }
            else
            {
                <div class="alert alert-info">
                    Nenhum produto encontrado.
                </div>
            }
        }
    </div>
</div>


@code {
    public IEnumerable<ProdutoDTO>? Produtos { get; set; }
    protected override async Task OnInitializedAsync()
    {
        Produtos = await produtoService.GetItens();
    }
}
